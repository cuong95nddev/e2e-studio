{
  "manifest_version": 3,
  "name": "E2E Studio",
  "version": "0.1.0",
  "description": "Capture browser test steps for E2E Studio",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"]
    }
  ],
  "action": {
    "default_title": "E2E Studio"
  }
}
